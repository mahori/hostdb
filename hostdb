#!/usr/bin/env ruby

require 'google/cloud/firestore'
require 'optparse'
require 'resolv'

def list(firestore, collection_name)
  hosts_ref = firestore.col(collection_name)
  hosts_ref.get do |host|
    name = host[:Name]
    ipv6 = host[:IPv6].join(' ')
    ipv4 = host[:IPv4].join(' ')

    message = sprintf('%-14s  %-39s  %-31s', name, ipv6, ipv4)
    puts message
  end
end

def search(firestore, collection_name, s)
  hosts_ref = firestore.col(collection_name)

  if s =~ Resolv::IPv6::Regex
    query = hosts_ref.where('IPv6', 'array-contains', s)
  elsif s =~ Resolv::IPv4::Regex
    query = hosts_ref.where('IPv4', 'array-contains', s)
  else
    query = hosts_ref.where('Name', '=', s)
  end

  query.get do |host|
    name = host[:Name]
    ipv6 = host[:IPv6].join(' ')
    ipv4 = host[:IPv4].join(' ')

    message = sprintf('%-14s  %-39s  %-31s', name, ipv6, ipv4)
    puts message
  end
end

def add(firestore, collection_name, name, ipv6, ipv4)
  ipv6_list = ipv6.split(',')
  ipv4_list = ipv4.split(',')

  doc_name = collection_name + '/' + name
  doc_ref = firestore.doc(doc_name)
  doc_ref.set(
    Type: 'server',
    Name: name,
    IPv6: ipv6_list,
    IPv4: ipv4_list
  )
end

def delete(firestore, collection_name, name)
  doc_name = collection_name + '/' + name
  doc_ref = firestore.doc(doc_name)
  doc_ref.delete
end

opts = ARGV.getopts('c:p:')
project_id = opts['p']
collection_name = opts['c']
if project_id.nil? or collection_name.nil?
  STDERR.puts 'options must be specified'
  exit 1
end

firestore = Google::Cloud::Firestore.new(project_id: project_id)

command = ARGV.shift
case command
when nil, 'l', 'list'
  list(firestore, collection_name)
when 's', 'search'
  search(firestore, collection_name, *ARGV)
when 'a', 'add'
  add(firestore, collection_name, *ARGV)
when 'd', 'delete'
  delete(firestore, collection_name, *ARGV)
else
  search(firestore, collection_name, command)
end

exit 0
