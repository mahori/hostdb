#!/usr/bin/env ruby

require 'google/cloud/firestore'
require 'optparse'
require 'resolv'

def print_documents(hosts)
  name_length = hosts.map { |host| host[:Name].length }
  max_name_length = name_length.max

  ipv6_size = hosts.map { |host| host[:IPv6].size }
  max_ipv6_size = ipv6_size.max

  ipv4_size = hosts.map { |host| host[:IPv4].size }
  max_ipv4_size = ipv4_size.max

  hosts.each do |host|
    format = sprintf('%%-%ds', max_name_length)
    message = sprintf(format, host[:Name])

    max_ipv6_size.times do |i|
      message += sprintf('  %-39s', host[:IPv6][i])
    end

    max_ipv4_size.times do |i|
      message += sprintf('  %-15s', host[:IPv4][i])
    end

    puts message
  end
end

def list(collection)
  hosts = collection.get

  print_documents(hosts)
end

def search(collection, *a)
  hosts = []

  a.each do |s|
    if s =~ Resolv::IPv6::Regex
      query = collection.where('IPv6', 'array-contains', s)
    elsif s =~ Resolv::IPv4::Regex
      query = collection.where('IPv4', 'array-contains', s)
    else
      query = collection.where('Name', '=', s)
    end

    query.get do |host|
      hosts.push(host)
    end
  end

  print_documents(hosts)
end

def add(collection, name, ipv6, ipv4)
  ipv6_list = ipv6.split(',')
  ipv4_list = ipv4.split(',')

  doc_ref = collection.doc(name)
  doc_ref.set({ Name: name, IPv6: ipv6_list, IPv4: ipv4_list })
end

def delete(collection, name)
  doc_ref = collection.doc(name)
  doc_ref.delete
end

opts = ARGV.getopts('c:p:')
project_id = opts['p']
collection_name = opts['c']
if project_id.nil? or collection_name.nil?
  STDERR.puts 'options must be specified'
  exit 1
end

firestore = Google::Cloud::Firestore.new(project_id: project_id)
collection = firestore.col(collection_name)

command = ARGV.shift
case command
when nil, 'l', 'list'
  list(collection)
when 's', 'search'
  search(collection, *ARGV)
when 'a', 'add'
  add(collection, *ARGV)
when 'd', 'delete'
  delete(collection, *ARGV)
else
  ARGV.unshift(command)
  search(collection, *ARGV)
end

exit 0
